# Copy this file to `.env` and fill in real values for local development.
# `.env` itself is in .gitignore and will never be committed.
# Quarkus automatically reads `.env` from the project root in dev mode.

# ---------- PGP ----------
# Point at your local key file (see secrets/ folder), never paste key content here.
PGP_PUBLIC_KEY_PATH=./secrets/public-key.asc

# ---------- Polling ----------
APP_POLL_CRON=0 */5 * * * ?
# ---------- SFTP ----------
# Defaults below already match the docker-compose "sftp" service - only
# uncomment/change these if you're pointing at a different SFTP server.
#SFTP_HOST=localhost
#SFTP_PORT=2222
#SFTP_USERNAME=testuser
#SFTP_PASSWORD=testpass
#SFTP_INPUT_DIR=/upload/input
#SFTP_OUTPUT_DIR=/upload/output